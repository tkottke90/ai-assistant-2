{
  "name": "@tkottke90/ai-assistant-client",
  "version": "0.1.0",
  "description": "SDK for interacting with the AI Assistant API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "dts-bundle-generator": "^9.5.1",
    "esbuild": "^0.20.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "keywords": [
    "ai-assistant",
    "api-client",
    "sdk"
  ],
  "author": "",
