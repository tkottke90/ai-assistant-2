generator client {
  provider = "prisma-client"
  output   = "../src/lib/prisma"
}

datasource db {
  provider = "sqlite"
}

model Node {
  node_id        Int      @id @default(autoincrement())
  type           String
  properties     Json
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now()) @updatedAt
  assets         Asset[]
  incoming_edges Edge[]   @relation("target")
  outgoing_edges Edge[]   @relation("source")

  @@index([type])
  @@index([created_at])
  @@index([updated_at])
}

model Edge {
  node_id    Int      @id @default(autoincrement())
  source_id  Int
  target_id  Int
  type       String
  properties Json
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
  target     Node     @relation("target", fields: [target_id], references: [node_id], onDelete: Cascade)
  source     Node     @relation("source", fields: [source_id], references: [node_id], onDelete: Cascade)

  @@unique([source_id, target_id, type])
  @@index([type])
  @@index([source_id])
  @@index([target_id])
  @@index([created_at])
  @@index([updated_at])
}

model Asset {
  asset_id    Int      @id @default(autoincrement())
  node_id     Int
  url         String
  mime_type   String?
  name        String?
  description String?
  nsfw        Boolean?
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt
  node        Node     @relation(fields: [node_id], references: [node_id], onDelete: Cascade)

  @@index([node_id])
  @@index([created_at])
  @@index([updated_at])
}

model Agent {
  agent_id      Int      @id @default(autoincrement())
  name          String
  description   String?
  version       Int      @default(1)
  system_prompt String
  auto_start    Boolean  @default(false)
  engine        String?
  model         String?
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now()) @updatedAt

  thread_metadata ThreadMetadata[]

  @@unique([name, version])
  @@index([created_at])
  @@index([updated_at])
}

model checkpoints {
  thread_id            String
  checkpoint_ns        String  @default("")
  checkpoint_id        String
  parent_checkpoint_id String?
  type                 String?
  checkpoint           Bytes?
  metadata             Bytes?

  @@id([thread_id, checkpoint_ns, checkpoint_id])
}

model writes {
  thread_id     String
  checkpoint_ns String  @default("")
  checkpoint_id String
  task_id       String
  idx           Int
  channel       String
  type          String?
  value         Bytes?

  @@id([thread_id, checkpoint_ns, checkpoint_id, task_id, idx])
}

model ThreadMetadata {
  thread_id  String   @id
  agent_id   Int?
  type       String   @default("chat")
  title      String?
  archived   Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  agent Agent? @relation(fields: [agent_id], references: [agent_id], onDelete: SetNull)

  @@index([agent_id])
  @@index([type])
  @@index([archived])
}
